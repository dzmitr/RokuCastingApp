<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
    <interface>
        <field id="launchParams" type="assocarray" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />

    <children>
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x060B13FF" />

        <Poster
            id="backgroundGradient"
            width="1920"
            height="1080"
            uri="pkg:/images/background-gradient.png"
            loadDisplayMode="scaleToFill" />

        <Video
            id="video"
            width="1920"
            height="1080"
            visible="false" />

        <Poster
            id="photoPosterA"
            width="1920"
            height="1080"
            loadDisplayMode="scaleToFit"
            visible="false" />

        <Poster
            id="photoPosterB"
            width="1920"
            height="1080"
            loadDisplayMode="scaleToFit"
            visible="false" />

        <Group id="overlay" visible="true">
            <Rectangle
                id="overlayScrim"
                width="1920"
                height="1080"
                color="0x09111CD6" />

            <Group id="bootSplashGroup" visible="true">
                <Poster
                    id="bootIconPoster"
                    uri="pkg:/images/ios-icon.png"
                    translation="[820, 334]"
                    width="280"
                    height="280"
                    loadDisplayMode="scaleToFit" />
            </Group>

            <Group id="standbyGroup" visible="false">
                <Poster
                    id="standbyIconPoster"
                    uri="pkg:/images/ios-icon.png"
                    translation="[828, 178]"
                    width="264"
                    height="264"
                    loadDisplayMode="scaleToFit" />

                <Label
                    id="standbyEyebrowLabel"
                    translation="[650, 486]"
                    width="620"
                    horizAlign="center"
                    text="TV Screen Mirror & Cast"
                    color="0x63D6FFFF" />

                <Label
                    id="standbyTitleLabel"
                    translation="[390, 554]"
                    width="1140"
                    horizAlign="center"
                    text="Start from your iPhone"
                    color="0xF4F8FFFF" />

                <Label
                    id="standbyMessageLabel"
                    translation="[430, 626]"
                    width="1060"
                    horizAlign="center"
                    text="Open Screen Mirroring: TV Air Cast on your iPhone to begin."
                    color="0xD7E4F7FF" />

                <Label
                    id="standbyFeaturesLabel"
                    translation="[500, 724]"
                    width="920"
                    horizAlign="center"
                    text="Photos   |   Videos   |   Screen"
                    color="0x76D7FFFF" />

                <Label
                    id="standbyAssistLabel"
                    translation="[520, 792]"
                    width="880"
                    horizAlign="center"
                    text="Make sure your iPhone and Roku are on the same Wi-Fi."
                    color="0x8FAFCDFF" />
            </Group>

            <Group id="statusPanelGroup" visible="false">
                <Rectangle
                    id="panelShadow"
                    width="980"
                    height="430"
                    translation="[470, 300]"
                    color="0x04070B99" />

                <Rectangle
                    id="panel"
                    width="980"
                    height="430"
                    translation="[458, 288]"
                    color="0x13213AF5" />

                <Rectangle
                    id="panelAccent"
                    width="980"
                    height="8"
                    translation="[458, 288]"
                    color="0x58CCFFFF" />

                <Rectangle
                    id="statusPill"
                    width="182"
                    height="48"
                    translation="[830, 360]"
                    color="0x27405FFF" />

                <BusySpinner
                    id="spinner"
                    translation="[1174, 362]"
                    visible="false" />

                <Poster
                    id="statusIconPoster"
                    uri="pkg:/images/ios-icon.png"
                    translation="[586, 360]"
                    width="160"
                    height="160"
                    loadDisplayMode="scaleToFit" />

                <Label
                    id="statusLabel"
                    translation="[854, 370]"
                    width="132"
                    horizAlign="center"
                    text="Loading"
                    color="0xF4F8FFFF" />

                <Label
                    id="eyebrowLabel"
                    translation="[786, 438]"
                    width="500"
                    text="ScreenCastTV Receiver"
                    color="0x8EB7EFFF" />

                <Label
                    id="titleLabel"
                    translation="[786, 492]"
                    width="500"
                    numLines="2"
                    text="Loading session..."
                    color="0xFFFFFFFF" />

                <Label
                    id="messageLabel"
                    translation="[786, 596]"
                    width="500"
                    numLines="3"
                    text="Fetching ScreenCastTV session details."
                    color="0xD7E1F5FF" />

                <Rectangle
                    id="footerDivider"
                    width="700"
                    height="2"
                    translation="[586, 668]"
                    color="0x27405FFF" />

                <Label
                    id="hintLabel"
                    translation="[586, 690]"
                    width="700"
                    horizAlign="center"
                    numLines="2"
                    text="This should only take a moment."
                    color="0x8EB7EFFF" />
            </Group>
        </Group>

        <Timer
            id="bootTimer"
            duration="1.4"
            repeat="false" />

        <SessionTask id="sessionTask" />
        <ControlPollTask id="controlTask" />
    </children>
</component>
